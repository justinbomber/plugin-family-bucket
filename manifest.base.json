{
  "manifest_version": 3,
  "name": "Plugin Family Bucket",
  "version": "0.1.0",
  "description": "多功能外掛全家桶平台（Infrastructure）",
  "permissions": ["storage"],
  "host_permissions": [],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Plugin Family Bucket",
    "default_popup": "src/popup/popup.html"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "commands": {},
  "content_scripts": [],
  "web_accessible_resources": []
}
