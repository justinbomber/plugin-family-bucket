{
  "_comment": "Plugin 級 manifest fragment：由 scripts/merge-manifest.mjs 合併至 plugin-family-bucket/manifest.json（勿更名為 manifest.json）",

  "permissions": ["tabs"],
  "host_permissions": ["https://*.youtube.com/*"],
  "commands": {
    "toggle-windowed-fullscreen": {
      "description": "切換 YouTube 視窗化滿版（YouTube Windowed Fullscreen）"
    }
  },
  "icons": {
    "16": "plugins/full-screen-toggle/assets/icon16.png",
    "32": "plugins/full-screen-toggle/assets/icon32.png",
    "48": "plugins/full-screen-toggle/assets/icon48.png",
    "128": "plugins/full-screen-toggle/assets/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "plugins/full-screen-toggle/src/shared/constants.js",
        "src/shared/message-types.js"
      ],
      "matches": ["https://*.youtube.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["plugins/full-screen-toggle/src/content/youtube-content.js"],
      "css": ["plugins/full-screen-toggle/src/content/youtube-content.css"],
      "run_at": "document_idle"
    }
  ]
}
